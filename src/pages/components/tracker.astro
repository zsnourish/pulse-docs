---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import trackerData from '../../data/component-tracker.json';

type Row = {
  component: string;
  variant?: string;
  platform: string;
  figmaDesigned?: boolean;
  vueBuilt?: boolean;
  vueBy?: string;
  vueUpdated?: string;
  reactBuilt?: boolean;
  reactBy?: string;
  reactUpdated?: string;
};

const rows: Row[] = trackerData.rows ?? [];

// Group consecutive rows by component + variant so the component/variant
// name only prints once per group (matching the rowspan look of the
// reference tracker), same as the source data's natural ordering.
type Group = { component: string; variant?: string; rows: Row[] };
const groups: Group[] = [];
for (const row of rows) {
  const last = groups[groups.length - 1];
  if (last && last.component === row.component && last.variant === row.variant) {
    last.rows.push(row);
  } else {
    groups.push({ component: row.component, variant: row.variant, rows: [row] });
  }
}

function fmtDate(d?: string) {
  if (!d) return '—';
  const date = new Date(d);
  return isNaN(date.getTime()) ? '—' : date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<StarlightPage frontmatter={{ title: 'Component Build Tracker', tableOfContents: false }}>
  <p>
    Cross-platform build status for Pulse components — Figma design, Vue build, and React build,
    tracked per platform. Edit via <a href="/admin/#/collections/component_tracker/entries/tracker">/admin</a>
    (Component Build Tracker collection). "By" is free text — name whoever actually built it, no
    collaborator account required.
  </p>

  <div class="tracker-table-wrap">
    <table class="tracker-table">
      <thead>
        <tr>
          <th rowspan="2" class="col-component">Component</th>
          <th rowspan="2" class="col-platform">Platform</th>
          <th class="group-figma">Figma</th>
          <th colspan="3" class="group-vue">Vue</th>
          <th colspan="3" class="group-react">React</th>
        </tr>
        <tr>
          <th class="group-figma">Designed?</th>
          <th class="group-vue">Built?</th>
          <th class="group-vue">By</th>
          <th class="group-vue">Updated</th>
          <th class="group-react">Built?</th>
          <th class="group-react">By</th>
          <th class="group-react">Updated</th>
        </tr>
      </thead>
      <tbody>
        {groups.map((group) => (
          <>
            {group.rows.map((row, i) => (
              <tr>
                {i === 0 && (
                  <td rowspan={group.rows.length} class="col-component">
                    <strong>{group.component}</strong>
                    {group.variant && <div class="variant">{group.variant}</div>}
                  </td>
                )}
                <td class="col-platform">{row.platform}</td>
                <td class="group-figma">{row.figmaDesigned ? '✓' : '—'}</td>
                <td class="group-vue">{row.vueBuilt ? '✓' : '—'}</td>
                <td class="group-vue">{row.vueBy || '—'}</td>
                <td class="group-vue">{fmtDate(row.vueUpdated)}</td>
                <td class="group-react">{row.reactBuilt ? '✓' : '—'}</td>
                <td class="group-react">{row.reactBy || '—'}</td>
                <td class="group-react">{fmtDate(row.reactUpdated)}</td>
              </tr>
            ))}
          </>
        ))}
      </tbody>
    </table>
  </div>
</StarlightPage>

<style>
  .tracker-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--pulse-neutral-40, #e7e8eb);
    border-radius: 0.75rem;
    margin-top: 1.5rem;
  }
  .tracker-table {
    border-collapse: collapse;
    width: 100%;
    font-size: 0.85rem;
  }
  .tracker-table th,
  .tracker-table td {
    border-bottom: 1px solid var(--pulse-neutral-40, #e7e8eb);
    border-right: 1px solid var(--pulse-neutral-40, #e7e8eb);
    padding: 0.5rem 0.75rem;
    text-align: left;
    vertical-align: middle;
  }
  .tracker-table th:last-child,
  .tracker-table td:last-child {
    border-right: none;
  }
  .tracker-table thead th {
    background: var(--pulse-neutral-20, #f9f9fa);
    font-weight: 700;
    text-align: center;
  }
  .tracker-table .col-component,
  .tracker-table .col-platform {
    text-align: left;
    background: var(--pulse-neutral-10, #fff);
  }
  .tracker-table .variant {
    font-size: 0.8rem;
    color: var(--pulse-neutral-90, #878e9d);
  }
  .tracker-table td.group-figma,
  .tracker-table td.group-vue,
  .tracker-table td.group-react {
    text-align: center;
  }
  .tracker-table th.group-vue,
  .tracker-table td.group-vue {
    background: color-mix(in srgb, var(--pulse-primary-70, #66cccc) 6%, white);
  }
  .tracker-table th.group-react,
  .tracker-table td.group-react {
    background: color-mix(in srgb, var(--pulse-success-70, #4bb97e) 6%, white);
  }
</style>
