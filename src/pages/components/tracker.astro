---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

const confluenceUrl = 'https://nourishcare.atlassian.net/wiki/spaces/Design/pages/1293647876/Component+Tracker';
---

<StarlightPage frontmatter={{ title: 'Component Build Tracker', tableOfContents: false }}>
  <p>
    Cross-platform build status for Pulse components — Figma design, Vue build, and React build,
    tracked per platform. This now lives in Confluence rather than here, so the team can edit rows
    without going through GitHub at all.
  </p>

  <p class="tracker-embed-note">
    <strong>Heads up:</strong> this embeds the real, published Confluence page (table now
    populated and cross-checked against Figma and Storybook) — but same as the Figma embeds
    elsewhere on this site, it usually only renders for people already signed into your
    organisation's Atlassian account, so anonymous visitors are likely to see a login wall instead
    of the table. Worth checking Confluence's sharing settings if this needs to be visible to
    people outside the org.
  </p>

  <div class="ds-embed">
    <iframe src={confluenceUrl} loading="lazy" allowfullscreen></iframe>
    <p class="ds-embed-caption">Component Build Tracker — Confluence (Pulse Components v1)</p>
  </div>
</StarlightPage>

<style>
  .tracker-embed-note {
    font-size: 0.85rem;
    color: var(--pulse-neutral-90, #878e9d);
    background: var(--pulse-neutral-20, #f9f9fa);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
  }
</style>
