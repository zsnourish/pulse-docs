---
// Standalone style customizer — not part of the Starlight docs nav.
// Lets a non-dev adjust colours/fonts/spacing with a live preview, then
// export a ready-to-use nourish-theme.css. This tool only runs in your
// browser; it doesn't write to GitHub, so download/copy the result and
// send it back (or push it yourself) to apply it.
//
// Scope note: this only covers CSS — visual styling (colour, font, spacing,
// roundness). Button/label *wording* (like Decap's "New doc" or "Publish")
// lives in config.yml / locale-en.js, not CSS, and isn't something a
// client-side style tool can safely rewrite — ask directly for wording
// changes and they'll get made in those files instead.
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pulse Docs — Theme Studio</title>
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: 'Inter', system-ui, sans-serif;
      background: #f9f9fa;
      color: #36393f;
      display: grid;
      grid-template-columns: 380px 1fr;
      min-height: 100vh;
    }
    aside {
      background: #fff;
      border-right: 1px solid #e7e8eb;
      padding: 1.5rem;
      overflow-y: auto;
      max-height: 100vh;
    }
    aside h1 { font-size: 1.1rem; margin: 0 0 0.25rem; }
    aside p.hint { font-size: 0.8rem; color: #878e9d; margin: 0 0 1rem; }
    aside h2.section {
      font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700;
      color: #878e9d; margin: 1.5rem 0 0.5rem; padding-top: 1rem; border-top: 1px solid #e7e8eb;
    }
    aside h2.section:first-of-type { border-top: none; padding-top: 0; margin-top: 1rem; }
    label { display: block; font-size: 0.8rem; font-weight: 600; margin: 0.85rem 0 0.3rem; }
    .color-row { display: flex; gap: 0.4rem; align-items: center; }
    input[type="color"] { width: 2.4rem; height: 2.2rem; border: 1px solid #e7e8eb; border-radius: 0.5rem; padding: 0.15rem; flex-shrink: 0; }
    input[type="text"].hex { flex: 1; font-family: monospace; text-transform: uppercase; }
    input[type="range"] { width: 100%; }
    select, input[type="text"] {
      width: 100%; padding: 0.5rem; border-radius: 0.5rem; border: 1px solid #e7e8eb; font-family: inherit; font-size: 0.85rem;
    }
    button.action {
      width: 100%; margin-top: 0.75rem; padding: 0.6rem; border-radius: 0.5rem; border: none;
      background: #2b5656; color: white; font-weight: 600; cursor: pointer; font-family: inherit;
    }
    button.action.secondary { background: #f3f4f5; color: #36393f; }
    .note {
      font-size: 0.75rem; color: #878e9d; background: #f9f9fa; border-radius: 0.5rem;
      padding: 0.6rem 0.75rem; margin-top: 0.5rem; line-height: 1.4;
    }
    main { padding: 2.5rem; overflow-y: auto; }
    .preview-card {
      background: var(--p-bg, #fff);
      border: 1px solid var(--p-neutral-40, #e7e8eb);
      border-radius: calc(var(--p-radius, 12) * 1px);
      padding: calc(2rem * var(--p-space, 1));
      max-width: 640px;
      font-family: var(--p-font, 'Inter', sans-serif);
      color: var(--p-text, #36393f);
    }
    .preview-card h2 { font-weight: 700; margin-top: 0; }
    .pv-btn {
      display: inline-block; padding: 0.55rem 1.1rem; border-radius: calc(var(--p-radius, 12) * 1px);
      background: var(--p-accent, #2b5656); color: white; font-weight: 600; font-size: 0.9rem; margin: 0.5rem 0.5rem 0.5rem 0;
    }
    .pv-callout {
      border-radius: calc(var(--p-radius, 12) * 1px); padding: 0.9rem 1.1rem; margin: 0.75rem 0; border: 1px solid transparent;
    }
    .pv-do { background: var(--p-success-bg, #edfcf4); border-color: var(--p-success, #4bb97e); }
    .pv-do strong { color: var(--p-success, #4bb97e); }
    .pv-dont { background: var(--p-urgency-bg, #fee7e7); border-color: var(--p-urgency, #cc5252); }
    .pv-dont strong { color: var(--p-urgency, #cc5252); }
    .pv-pill {
      display: inline-block; padding: 0.15rem 0.6rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600;
      text-transform: uppercase; background: var(--p-success-bg, #edfcf4); color: var(--p-success, #4bb97e);
    }
    .pv-sidebar {
      width: 220px; background: #f9f9fa; border-radius: calc(var(--p-radius, 12) * 1px); padding: 1rem; margin-top: 1.5rem;
    }
    .pv-sidebar .group {
      font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700;
      margin-top: calc(0.9rem * var(--p-sidebar-gap, 1)); margin-bottom: 0.3rem;
    }
    .pv-sidebar .group:nth-of-type(1) { color: var(--p-cat-foundations, #2b5656); }
    .pv-sidebar .group:nth-of-type(3) { color: var(--p-cat-components, #2b5656); }
    .pv-sidebar .group:nth-of-type(5) { color: var(--p-cat-visuals, #2b5656); }
    .pv-sidebar .active {
      background: var(--p-accent-low, #f0fafa); color: var(--p-accent, #2b5656); border-radius: 0.5rem;
      padding: 0.4rem 0.6rem; font-weight: 600; font-size: 0.9rem; display: block;
      margin-bottom: calc(0.3rem * var(--p-sidebar-gap, 1));
    }
    .pv-sidebar .item {
      padding: 0.4rem 0.6rem; font-size: 0.9rem; color: #878e9d; display: block;
      margin-bottom: calc(0.15rem * var(--p-sidebar-gap, 1));
    }
    textarea#cssOut {
      width: 100%; height: 220px; margin-top: 1rem; font-family: monospace; font-size: 0.7rem;
      padding: 0.75rem; border-radius: 0.5rem; border: 1px solid #e7e8eb; background: #f9f9fa;
    }
  </style>
</head>
<body>
  <aside>
    <h1>Theme Studio</h1>
    <p class="hint">Adjust Pulse's docs theme. Nothing here writes to GitHub — copy or download the CSS when you're happy, and push it (or send it back).</p>

    <h2 class="section">Core brand</h2>

    <label>Accent (links, buttons)</label>
    <div class="color-row">
      <input type="color" id="accent" value="#2b5656" />
      <input type="text" class="hex" id="accentHex" value="#2B5656" />
    </div>

    <label>Brand teal (chips, highlights)</label>
    <div class="color-row">
      <input type="color" id="brandTeal" value="#66cccc" />
      <input type="text" class="hex" id="brandTealHex" value="#66CCCC" />
    </div>

    <label>Success</label>
    <div class="color-row">
      <input type="color" id="success" value="#4bb97e" />
      <input type="text" class="hex" id="successHex" value="#4BB97E" />
    </div>

    <label>Urgency / error</label>
    <div class="color-row">
      <input type="color" id="urgency" value="#cc5252" />
      <input type="text" class="hex" id="urgencyHex" value="#CC5252" />
    </div>

    <label>Body text colour</label>
    <div class="color-row">
      <input type="color" id="text" value="#36393f" />
      <input type="text" class="hex" id="textHex" value="#36393F" />
    </div>

    <label>Page background</label>
    <div class="color-row">
      <input type="color" id="bg" value="#ffffff" />
      <input type="text" class="hex" id="bgHex" value="#FFFFFF" />
    </div>

    <h2 class="section">Per-category sidebar colour</h2>

    <label>Foundations</label>
    <div class="color-row">
      <input type="color" id="catFoundations" value="#2b5656" />
      <input type="text" class="hex" id="catFoundationsHex" value="#2B5656" />
    </div>

    <label>Components</label>
    <div class="color-row">
      <input type="color" id="catComponents" value="#2b5656" />
      <input type="text" class="hex" id="catComponentsHex" value="#2B5656" />
    </div>

    <label>Visuals</label>
    <div class="color-row">
      <input type="color" id="catVisuals" value="#2b5656" />
      <input type="text" class="hex" id="catVisualsHex" value="#2B5656" />
    </div>

    <h2 class="section">Type & spacing</h2>

    <label>Font family</label>
    <select id="font">
      <option value="'Inter', system-ui, sans-serif" selected>Inter (current)</option>
      <option value="system-ui, -apple-system, sans-serif">System UI</option>
      <option value="'Georgia', serif">Georgia (serif)</option>
      <option value="'Poppins', system-ui, sans-serif">Poppins</option>
      <option value="'Source Sans 3', system-ui, sans-serif">Source Sans 3</option>
    </select>

    <label>Corner roundness: <span id="radiusVal">12px</span></label>
    <input type="range" id="radius" min="0" max="24" value="12" />

    <label>Content spacing scale: <span id="spaceVal">1.0x</span></label>
    <input type="range" id="space" min="0.8" max="1.4" step="0.05" value="1" />

    <label>Sidebar item spacing: <span id="sidebarGapVal">1.0x</span></label>
    <input type="range" id="sidebarGap" min="0.6" max="2" step="0.1" value="1" />

    <button class="action" id="copyBtn">Copy CSS to clipboard</button>
    <button class="action secondary" id="downloadBtn">Download nourish-theme.css</button>

    <div class="note">
      <strong>Not covered here:</strong> button/label text (e.g. Decap's "New doc", "Publish", homepage card titles) is content, not CSS — it lives in <code>config.yml</code> / <code>locale-en.js</code>. Ask directly for wording changes.
    </div>

    <textarea id="cssOut" readonly></textarea>
  </aside>

  <main>
    <div class="preview-card">
      <span class="pv-pill">Approved</span>
      <h2>Button</h2>
      <p>Primary buttons are the most important action on a screen. These should be used sparingly, usually only one per screen.</p>
      <a class="pv-btn">Save changes</a>

      <div class="pv-callout pv-do">
        <p><strong>✓ Do</strong> — Use action-oriented labels starting with a strong verb, e.g. "Save".</p>
      </div>
      <div class="pv-callout pv-dont">
        <p><strong>✗ Don't</strong> — Use vague terms like "Continue".</p>
      </div>

      <div class="pv-sidebar">
        <div class="group">Foundations</div>
        <span class="active">Colour</span>
        <div class="group">Components</div>
        <span class="item">Button</span>
        <div class="group">Visuals</div>
        <span class="item">Iconography</span>
      </div>
    </div>
  </main>

  <script>
    const $ = (id) => document.getElementById(id);
    const root = document.documentElement;

    function hexToRgbaBg(hex, alpha) {
      const r = parseInt(hex.slice(1, 3), 16);
      const g = parseInt(hex.slice(3, 5), 16);
      const b = parseInt(hex.slice(5, 7), 16);
      return `rgba(${r}, ${g}, ${b}, ${alpha})`;
    }

    // Two-way binding between a <input type=color> and its paired hex text field.
    function bindColorPair(colorId, hexId) {
      const colorEl = $(colorId);
      const hexEl = $(hexId);
      colorEl.addEventListener('input', () => {
        hexEl.value = colorEl.value.toUpperCase();
        update();
      });
      hexEl.addEventListener('input', () => {
        const v = hexEl.value.trim();
        if (/^#[0-9a-fA-F]{6}$/.test(v)) {
          colorEl.value = v;
          update();
        }
      });
    }

    ['accent', 'brandTeal', 'success', 'urgency', 'text', 'bg', 'catFoundations', 'catComponents', 'catVisuals'].forEach(
      (id) => bindColorPair(id, id + 'Hex')
    );

    function update() {
      const accent = $('accent').value;
      const brandTeal = $('brandTeal').value;
      const success = $('success').value;
      const urgency = $('urgency').value;
      const text = $('text').value;
      const bg = $('bg').value;
      const catFoundations = $('catFoundations').value;
      const catComponents = $('catComponents').value;
      const catVisuals = $('catVisuals').value;
      const font = $('font').value;
      const radius = $('radius').value;
      const space = $('space').value;
      const sidebarGap = $('sidebarGap').value;

      $('radiusVal').textContent = radius + 'px';
      $('spaceVal').textContent = space + 'x';
      $('sidebarGapVal').textContent = sidebarGap + 'x';

      root.style.setProperty('--p-accent', accent);
      root.style.setProperty('--p-accent-low', hexToRgbaBg(accent, 0.08));
      root.style.setProperty('--p-success', success);
      root.style.setProperty('--p-success-bg', hexToRgbaBg(success, 0.12));
      root.style.setProperty('--p-urgency', urgency);
      root.style.setProperty('--p-urgency-bg', hexToRgbaBg(urgency, 0.12));
      root.style.setProperty('--p-text', text);
      root.style.setProperty('--p-bg', bg);
      root.style.setProperty('--p-font', font);
      root.style.setProperty('--p-radius', radius);
      root.style.setProperty('--p-space', space);
      root.style.setProperty('--p-sidebar-gap', sidebarGap);
      root.style.setProperty('--p-cat-foundations', catFoundations);
      root.style.setProperty('--p-cat-components', catComponents);
      root.style.setProperty('--p-cat-visuals', catVisuals);
      document.querySelector('main').style.fontFamily = font;

      const css = `/**
 * Pulse (Nourish) branding for Starlight.
 * Generated by Theme Studio (/theme-studio) — hand-edit or regenerate as needed.
 */

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

:root {
  --sl-font: ${font};
  --sl-font-headings: ${font};

  --pulse-primary-100: ${accent};
  --pulse-primary-70:  ${brandTeal};
  --pulse-primary-10:  ${hexToRgbaBg(accent, 0.06)};

  --pulse-neutral-120: ${text};
  --pulse-neutral-20:  #f9f9fa;
  --pulse-neutral-10:  ${bg};

  --pulse-success-70:  ${success};
  --pulse-success-20:  ${hexToRgbaBg(success, 0.12)};
  --pulse-urgency-70:  ${urgency};
  --pulse-urgency-20:  ${hexToRgbaBg(urgency, 0.12)};

  --sl-color-accent: ${accent};
  --sl-color-accent-high: ${accent};
  --sl-color-text-accent: ${accent};
  --sl-color-bg: ${bg};
  --sl-color-text: ${text};
  --sl-border-radius: ${radius}px;
}

h1, h2, h3, h4, h5 { font-weight: 700; letter-spacing: -0.01em; }

.card, .sl-markdown-content pre, .sl-markdown-content table { border-radius: ${radius}px !important; }

/* Sidebar item spacing */
.sidebar-pane nav .top-level > li { margin-bottom: calc(0.2rem * ${sidebarGap}); }
.sidebar-pane nav a.large,
.sidebar-pane nav details > summary { padding-block: calc(0.35rem * ${sidebarGap}); }

/* Per-category sidebar group colour (order: Foundations, Components, Visuals) */
.sidebar-pane .top-level > li:nth-of-type(1) .group-label .large { color: ${catFoundations}; }
.sidebar-pane .top-level > li:nth-of-type(2) .group-label .large { color: ${catComponents}; }
.sidebar-pane .top-level > li:nth-of-type(3) .group-label .large { color: ${catVisuals}; }

.status-pill { display: inline-block; padding: 0.15rem 0.6rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; }
.status-pill[data-status='approved'] { background: ${hexToRgbaBg(success, 0.12)}; color: ${success}; }
.status-pill[data-status='deprecated'] { background: ${hexToRgbaBg(urgency, 0.12)}; color: ${urgency}; }

.ds-callout { border-radius: ${radius}px; padding: calc(0.9rem * ${space}) calc(1.1rem * ${space}); margin: 1rem 0; border: 1px solid transparent; }
.ds-do { background: ${hexToRgbaBg(success, 0.12)}; border-color: ${success}; }
.ds-do strong { color: ${success}; }
.ds-dont { background: ${hexToRgbaBg(urgency, 0.12)}; border-color: ${urgency}; }
.ds-dont strong { color: ${urgency}; }
`;
      $('cssOut').value = css;
    }

    [
      'accent', 'brandTeal', 'success', 'urgency', 'text', 'bg',
      'catFoundations', 'catComponents', 'catVisuals',
      'font', 'radius', 'space', 'sidebarGap',
    ].forEach((id) => {
      $(id).addEventListener('input', update);
    });

    $('copyBtn').addEventListener('click', () => {
      navigator.clipboard.writeText($('cssOut').value);
      $('copyBtn').textContent = 'Copied!';
      setTimeout(() => ($('copyBtn').textContent = 'Copy CSS to clipboard'), 1500);
    });

    $('downloadBtn').addEventListener('click', () => {
      const blob = new Blob([$('cssOut').value], { type: 'text/css' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'nourish-theme.css';
      a.click();
      URL.revokeObjectURL(url);
    });

    update();
  </script>
</body>
</html>
