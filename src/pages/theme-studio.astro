---
// Standalone style customizer — not part of the Starlight docs nav.
// Lets a non-dev adjust colours/fonts/spacing with a live preview, then
// export a ready-to-use nourish-theme.css. This tool only runs in your
// browser; it doesn't write to GitHub, so download/copy the result and
// send it back (or push it yourself) to apply it.
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pulse Docs — Theme Studio</title>
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: 'Inter', system-ui, sans-serif;
      background: #f9f9fa;
      color: #36393f;
      display: grid;
      grid-template-columns: 340px 1fr;
      min-height: 100vh;
    }
    aside {
      background: #fff;
      border-right: 1px solid #e7e8eb;
      padding: 1.5rem;
      overflow-y: auto;
    }
    aside h1 { font-size: 1.1rem; margin: 0 0 0.25rem; }
    aside p.hint { font-size: 0.8rem; color: #878e9d; margin: 0 0 1.5rem; }
    label { display: block; font-size: 0.8rem; font-weight: 600; margin: 1rem 0 0.3rem; }
    input[type="color"] { width: 100%; height: 2.2rem; border: 1px solid #e7e8eb; border-radius: 0.5rem; padding: 0.15rem; }
    input[type="range"] { width: 100%; }
    select, input[type="text"] {
      width: 100%; padding: 0.5rem; border-radius: 0.5rem; border: 1px solid #e7e8eb; font-family: inherit;
    }
    .row { display: flex; gap: 0.5rem; }
    .row > div { flex: 1; }
    button.action {
      width: 100%; margin-top: 0.75rem; padding: 0.6rem; border-radius: 0.5rem; border: none;
      background: #2b5656; color: white; font-weight: 600; cursor: pointer; font-family: inherit;
    }
    button.action.secondary { background: #f3f4f5; color: #36393f; }
    main { padding: 2.5rem; overflow-y: auto; }
    .preview-card {
      background: var(--p-bg, #fff);
      border: 1px solid var(--p-neutral-40, #e7e8eb);
      border-radius: calc(var(--p-radius, 12) * 1px);
      padding: calc(2rem * var(--p-space, 1));
      max-width: 640px;
      font-family: var(--p-font, 'Inter', sans-serif);
      color: var(--p-text, #36393f);
    }
    .preview-card h2 { font-weight: 700; margin-top: 0; }
    .pv-btn {
      display: inline-block; padding: 0.55rem 1.1rem; border-radius: calc(var(--p-radius, 12) * 1px);
      background: var(--p-accent, #2b5656); color: white; font-weight: 600; font-size: 0.9rem; margin: 0.5rem 0.5rem 0.5rem 0;
    }
    .pv-callout {
      border-radius: calc(var(--p-radius, 12) * 1px); padding: 0.9rem 1.1rem; margin: 0.75rem 0; border: 1px solid transparent;
    }
    .pv-do { background: var(--p-success-bg, #edfcf4); border-color: var(--p-success, #4bb97e); }
    .pv-do strong { color: var(--p-success, #4bb97e); }
    .pv-dont { background: var(--p-urgency-bg, #fee7e7); border-color: var(--p-urgency, #cc5252); }
    .pv-dont strong { color: var(--p-urgency, #cc5252); }
    .pv-pill {
      display: inline-block; padding: 0.15rem 0.6rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600;
      text-transform: uppercase; background: var(--p-success-bg, #edfcf4); color: var(--p-success, #4bb97e);
    }
    .pv-sidebar {
      width: 200px; background: #f9f9fa; border-radius: calc(var(--p-radius, 12) * 1px); padding: 1rem; margin-top: 1.5rem;
    }
    .pv-sidebar .active {
      background: var(--p-accent-low, #f0fafa); color: var(--p-accent, #2b5656); border-radius: 0.5rem;
      padding: 0.4rem 0.6rem; font-weight: 600; font-size: 0.9rem; display: block; margin-bottom: 0.3rem;
    }
    .pv-sidebar .item { padding: 0.4rem 0.6rem; font-size: 0.9rem; color: #878e9d; display: block; }
    textarea#cssOut {
      width: 100%; height: 260px; margin-top: 1rem; font-family: monospace; font-size: 0.75rem;
      padding: 0.75rem; border-radius: 0.5rem; border: 1px solid #e7e8eb; background: #f9f9fa;
    }
  </style>
</head>
<body>
  <aside>
    <h1>Theme Studio</h1>
    <p class="hint">Adjust Pulse's docs theme. Nothing here writes to GitHub — copy or download the CSS when you're happy, and push it (or send it back).</p>

    <label>Accent colour (links, buttons)</label>
    <input type="color" id="accent" value="#2b5656" />

    <label>Brand teal (chips, highlights)</label>
    <input type="color" id="brandTeal" value="#66cccc" />

    <div class="row">
      <div>
        <label>Success</label>
        <input type="color" id="success" value="#4bb97e" />
      </div>
      <div>
        <label>Urgency / error</label>
        <input type="color" id="urgency" value="#cc5252" />
      </div>
    </div>

    <label>Body text colour</label>
    <input type="color" id="text" value="#36393f" />

    <label>Page background</label>
    <input type="color" id="bg" value="#ffffff" />

    <label>Font family</label>
    <select id="font">
      <option value="'Inter', system-ui, sans-serif" selected>Inter (current)</option>
      <option value="system-ui, -apple-system, sans-serif">System UI</option>
      <option value="'Georgia', serif">Georgia (serif)</option>
      <option value="'Poppins', system-ui, sans-serif">Poppins</option>
      <option value="'Source Sans 3', system-ui, sans-serif">Source Sans 3</option>
    </select>

    <label>Corner roundness: <span id="radiusVal">12px</span></label>
    <input type="range" id="radius" min="0" max="24" value="12" />

    <label>Spacing scale: <span id="spaceVal">1.0x</span></label>
    <input type="range" id="space" min="0.8" max="1.4" step="0.05" value="1" />

    <button class="action" id="copyBtn">Copy CSS to clipboard</button>
    <button class="action secondary" id="downloadBtn">Download nourish-theme.css</button>

    <textarea id="cssOut" readonly></textarea>
  </aside>

  <main>
    <div class="preview-card">
      <span class="pv-pill">Approved</span>
      <h2>Button</h2>
      <p>Primary buttons are the most important action on a screen. These should be used sparingly, usually only one per screen.</p>
      <a class="pv-btn">Save changes</a>

      <div class="pv-callout pv-do">
        <p><strong>✓ Do</strong> — Use action-oriented labels starting with a strong verb, e.g. "Save".</p>
      </div>
      <div class="pv-callout pv-dont">
        <p><strong>✗ Don't</strong> — Use vague terms like "Continue".</p>
      </div>

      <div class="pv-sidebar">
        <span class="active">Components</span>
        <span class="item">Guides</span>
        <span class="item">Foundations</span>
      </div>
    </div>
  </main>

  <script>
    const $ = (id) => document.getElementById(id);
    const root = document.documentElement;

    function hexToRgbaBg(hex, alpha) {
      const r = parseInt(hex.slice(1, 3), 16);
      const g = parseInt(hex.slice(3, 5), 16);
      const b = parseInt(hex.slice(5, 7), 16);
      return `rgba(${r}, ${g}, ${b}, ${alpha})`;
    }

    function update() {
      const accent = $('accent').value;
      const brandTeal = $('brandTeal').value;
      const success = $('success').value;
      const urgency = $('urgency').value;
      const text = $('text').value;
      const bg = $('bg').value;
      const font = $('font').value;
      const radius = $('radius').value;
      const space = $('space').value;

      $('radiusVal').textContent = radius + 'px';
      $('spaceVal').textContent = space + 'x';

      root.style.setProperty('--p-accent', accent);
      root.style.setProperty('--p-accent-low', hexToRgbaBg(accent, 0.08));
      root.style.setProperty('--p-success', success);
      root.style.setProperty('--p-success-bg', hexToRgbaBg(success, 0.12));
      root.style.setProperty('--p-urgency', urgency);
      root.style.setProperty('--p-urgency-bg', hexToRgbaBg(urgency, 0.12));
      root.style.setProperty('--p-text', text);
      root.style.setProperty('--p-bg', bg);
      root.style.setProperty('--p-font', font);
      root.style.setProperty('--p-radius', radius);
      root.style.setProperty('--p-space', space);
      document.querySelector('main').style.fontFamily = font;

      const css = `/**
 * Pulse (Nourish) branding for Starlight.
 * Generated by Theme Studio (/theme-studio) — hand-edit or regenerate as needed.
 */

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

:root {
  --sl-font: ${font};
  --sl-font-headings: ${font};

  --pulse-primary-100: ${accent};
  --pulse-primary-70:  ${brandTeal};
  --pulse-primary-10:  ${hexToRgbaBg(accent, 0.06)};

  --pulse-neutral-120: ${text};
  --pulse-neutral-20:  #f9f9fa;
  --pulse-neutral-10:  ${bg};

  --pulse-success-70:  ${success};
  --pulse-success-20:  ${hexToRgbaBg(success, 0.12)};
  --pulse-urgency-70:  ${urgency};
  --pulse-urgency-20:  ${hexToRgbaBg(urgency, 0.12)};

  --sl-color-accent: ${accent};
  --sl-color-accent-high: ${accent};
  --sl-color-text-accent: ${accent};
  --sl-color-bg: ${bg};
  --sl-color-text: ${text};
  --sl-border-radius: ${radius}px;
}

h1, h2, h3, h4, h5 { font-weight: 700; letter-spacing: -0.01em; }

.card, .sl-markdown-content pre, .sl-markdown-content table { border-radius: ${radius}px !important; }

.status-pill { display: inline-block; padding: 0.15rem 0.6rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; }
.status-pill[data-status='approved'] { background: ${hexToRgbaBg(success, 0.12)}; color: ${success}; }
.status-pill[data-status='deprecated'] { background: ${hexToRgbaBg(urgency, 0.12)}; color: ${urgency}; }

.ds-callout { border-radius: ${radius}px; padding: calc(0.9rem * ${space}) calc(1.1rem * ${space}); margin: 1rem 0; border: 1px solid transparent; }
.ds-do { background: ${hexToRgbaBg(success, 0.12)}; border-color: ${success}; }
.ds-do strong { color: ${success}; }
.ds-dont { background: ${hexToRgbaBg(urgency, 0.12)}; border-color: ${urgency}; }
.ds-dont strong { color: ${urgency}; }
`;
      $('cssOut').value = css;
    }

    ['accent','brandTeal','success','urgency','text','bg','font','radius','space'].forEach((id) => {
      $(id).addEventListener('input', update);
    });

    $('copyBtn').addEventListener('click', () => {
      navigator.clipboard.writeText($('cssOut').value);
      $('copyBtn').textContent = 'Copied!';
      setTimeout(() => ($('copyBtn').textContent = 'Copy CSS to clipboard'), 1500);
    });

    $('downloadBtn').addEventListener('click', () => {
      const blob = new Blob([$('cssOut').value], { type: 'text/css' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'nourish-theme.css';
      a.click();
      URL.revokeObjectURL(url);
    });

    update();
  </script>
</body>
</html>
